---
import Layout from '../layouts/Layout.astro';

const email = Astro.url.searchParams.get('email')?.trim() ?? '';
const safeEmail = email || 'your inbox';
---

<Layout
	title="Private Walkthrough | Sidecar Brand Consultancy"
	description="Watch the sidecar brand walkthrough and take the next step if you want help building your own."
>
	<main class="min-h-screen bg-white text-black">
		<div class="mx-auto max-w-6xl px-5 py-6 md:px-8 md:py-8">
			<section class="border-4 border-black bg-white px-6 py-8 md:px-10 md:py-10">
				<p class="text-[11px] font-bold uppercase tracking-[0.28em] text-slate-700">Private access unlocked</p>
				<h1 class="mt-4 max-w-4xl font-serif text-4xl leading-none md:text-7xl">
					Here is the walkthrough.
				</h1>
				<p class="mt-5 max-w-2xl text-base leading-7 text-slate-700 md:text-xl">
					We sent a note to <span class="font-bold">{safeEmail}</span>. If you want help building this for
					your business, the next step is right below the video.
				</p>
			</section>

			<section class="mt-5 border-4 border-black bg-black p-3 md:p-4">
				<div class="border-4 border-teal-400 bg-black p-4 md:p-6">
					<div class="flex min-h-[360px] items-center justify-center border-4 border-white bg-slate-950 px-6 text-center text-white md:min-h-[620px]">
						<div>
							<p class="text-sm font-bold uppercase tracking-[0.35em] text-teal-300">Video Walkthrough</p>
							<h2 class="mt-4 font-serif text-4xl leading-none md:text-6xl">Embed The Video Here</h2>
							<p class="mt-4 text-base text-slate-300 md:text-lg">
								Replace this block with your actual walkthrough embed.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="mt-5 grid gap-4 md:grid-cols-2">
				<div class="border-4 border-black bg-teal-100 p-5">
					<p class="text-[11px] font-bold uppercase tracking-[0.28em] text-teal-700">What this shows</p>
					<h2 class="mt-3 font-serif text-2xl leading-none md:text-4xl">How the sidecar brand works</h2>
					<p class="mt-3 text-sm leading-6 text-slate-700">
						Channel. Offer. Monetization stack. Clear first moves.
					</p>
				</div>
				<div class="border-4 border-black bg-white p-5">
					<p class="text-[11px] font-bold uppercase tracking-[0.28em] text-slate-700">Want help?</p>
					<h2 class="mt-3 font-serif text-2xl leading-none md:text-4xl">Book the strategy call</h2>
					<p class="mt-3 text-sm leading-6 text-slate-700">
						If you want us to map or build your sidecar brand, use the link below.
					</p>
					<a
						href="https://cal.com/your-link"
						target="_blank"
						rel="noreferrer"
						class="mt-5 inline-flex items-center justify-center border-4 border-black bg-teal-500 px-6 py-3 text-sm font-bold uppercase tracking-[0.14em] text-black transition hover:bg-teal-400"
					>
						Book The Strategy Call
					</a>
				</div>
			</section>
		</div>
	</main>
</Layout>
